{
  "name": "contentbridge-extension",
  "displayName": "ContentBridge — 多平台内容发布",
  "version": "2.0.0",
  "description": "一次创作，多端适配。自动发布到公众号、知乎、B站、小红书",
  "author": "xyh202131",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.9.0",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "lucide-react": "^0.547.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "plasmo": "^0.89.0",
    "playwright": "^1.60.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.3"
  },
  "manifest": {
    "host_permissions": [
      "https://mp.weixin.qq.com/*",
      "https://zhuanlan.zhihu.com/*",
      "https://member.bilibili.com/*",
      "https://creator.xiaohongshu.com/*"
    ],
    "permissions": [
      "sidePanel",
      "storage",
      "tabs",
      "activeTab",
      "scripting",
      "alarms",
      "clipboardWrite"
    ],
    "key": "",
    "externally_connectable": {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "http://localhost:5175/*",
        "http://localhost:5176/*",
        "http://localhost:5177/*",
        "http://localhost:5178/*",
        "http://localhost:5179/*",
        "http://localhost:5180/*",
        "http://localhost:3000/*",
        "http://localhost:4173/*"
      ]
    }
  }
}
